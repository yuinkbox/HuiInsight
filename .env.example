# ============================================================================
# AHDUNYI Terminal PRO - 环境变量配置文件模板
# ============================================================================
# 说明：
# 1. 复制此文件为 .env 并根据环境重命名（如 .env.development, .env.production）
# 2. 不要将包含真实敏感信息的 .env 文件提交到版本控制
# 3. 使用 .env.example 作为模板，在部署时创建实际的 .env 文件
# ============================================================================

# ============================================================================
# 通用配置
# ============================================================================

# 环境类型：development, production, test
ENVIRONMENT=development

# 应用名称
APP_NAME=AHDUNYI Terminal PRO

# 应用版本
APP_VERSION=9.1.0

# 调试模式开关
DEBUG=true

# ============================================================================
# 后端服务配置
# ============================================================================

# 数据库连接字符串
# 格式：mysql+pymysql://用户名:密码@主机:端口/数据库名?charset=utf8mb4
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/ahdunyi_pro_db?charset=utf8mb4

# JWT 密钥（至少32位）
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# JWT 算法
JWT_ALGORITHM=HS256

# JWT 访问令牌过期时间（秒）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# 服务器主机地址
SERVER_HOST=0.0.0.0

# 服务器端口
SERVER_PORT=8000

# ============================================================================
# 前端服务配置
# ============================================================================

# API 基础地址（开发环境）
VITE_API_BASE_URL_DEVELOPMENT=http://localhost:8000

# API 基础地址（生产环境）
VITE_API_BASE_URL_PRODUCTION=http://106.15.32.246:8000

# API 基础地址（测试环境）
VITE_API_BASE_URL_TEST=http://test-server:8000

# API 请求超时时间（毫秒）
VITE_API_TIMEOUT=10000

# 应用标题
VITE_APP_TITLE=HuiInsight 徽鉴

# 应用版本
VITE_APP_VERSION=9.1.0

# 版权信息
VITE_APP_COPYRIGHT=© 2026 HuiInsight. The Infrastructure of Risk Control.

# 客户端类型：web 或 desktop
VITE_CLIENT_TYPE=web

# 日志级别：debug, info, warn, error
VITE_LOG_LEVEL=info

# 是否启用控制台日志
VITE_CONSOLE_LOG=true

# 是否启用 Mock 数据
VITE_ENABLE_MOCK=false

# ============================================================================
# 桌面客户端配置
# ============================================================================

# 服务器地址（桌面客户端使用）
DESKTOP_SERVER_URL=http://localhost:8000

# 窗口宽度
DESKTOP_WINDOW_WIDTH=1440

# 窗口高度
DESKTOP_WINDOW_HEIGHT=900

# 日志级别
DESKTOP_LOG_LEVEL=INFO

# 日志文件
DESKTOP_LOG_FILE=client.log

# 是否启用控制台
DESKTOP_ENABLE_CONSOLE=false

# ============================================================================
# 功能开关
# ============================================================================

# 是否自动启动房间监控
FEATURE_AUTO_START_MONITOR=true

# 内存探测是否启用
FEATURE_MEMORY_PROBE_ENABLED=true

# 内存合并模式
FEATURE_MEMORY_MERGE_MODE=override

# ============================================================================
# 路径配置
# ============================================================================

# 日志目录
PATH_LOGS_DIRECTORY=logs

# 数据目录
PATH_DATA_DIRECTORY=data

# ============================================================================
# 安全配置
# ============================================================================

# 密码哈希算法
PASSWORD_HASH_ALGORITHM=bcrypt

# 密码哈希轮数
PASSWORD_HASH_ROUNDS=12

# ============================================================================
# 监控配置
# ============================================================================

# 目标进程名称
MONITOR_TARGET_PROCESS=small_dimple.exe

# 心跳间隔（秒）
MONITOR_HEARTBEAT_INTERVAL=2.0

# 最大搜索深度
MONITOR_MAX_SEARCH_DEPTH=8

# 内存最大区域字节数
MONITOR_MEMORY_MAX_REGION_BYTES=524288

# 内存最大总字节数
MONITOR_MEMORY_MAX_TOTAL_BYTES=12582912