{
  "name": "web-client",
  "version": "1.0.0",
  "description": "商业级 Web 前端项目 - Vue 3 + Arco Design",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:development": "vue-tsc && vite build --mode development",
    "build:production": "vue-tsc && vite build --mode production",
    "build:test": "vue-tsc && vite build --mode test",
    "preview": "vite preview",
    "preview:development": "vite preview --mode development",
    "preview:production": "vite preview --mode production",
    "preview:test": "vite preview --mode test",
    "type-check": "vue-tsc --noEmit",
    "type-check:watch": "vue-tsc --noEmit --watch",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.56.0",
    "@vueuse/core": "^10.7.0",
    "axios": "^1.13.6",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.19.0",
    "less": "^4.6.4",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
