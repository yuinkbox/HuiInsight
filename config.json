{
  "display_name": "AHDUNYI Terminal PRO",
  "version": "1.0.0",
  "server": {
    "url": "http://106.15.32.246:8000"
  },
  "gui": {
    "window_width": 1440,
    "window_height": 900
  },
  "logging": {
    "level": "INFO",
