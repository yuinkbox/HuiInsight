# ==================== 前端环境配置 ====================
# 运行环境: development | test | production
VITE_ENV=development

# ==================== API服务器配置 ====================
# 开发环境
# VITE_API_BASE_URL=http://localhost:8000

# 测试环境 (体验服)
# VITE_API_BASE_URL=https://test.ahdunyi.com:8000

# 生产环境 (正式服) - 阿里云服务器
VITE_API_BASE_URL=http://106.15.32.246:8000

# ==================== 应用配置 ====================
VITE_APP_TITLE=AHDUNYI 风控审核中台
VITE_APP_VERSION=2.0.0
VITE_APP_COPYRIGHT=© 2026 AHDUNYI

# ==================== 功能开关 ====================
# 是否启用调试模式
VITE_DEBUG=true

# 是否启用Mock数据
VITE_ENABLE_MOCK=false

# 请求超时时间 (毫秒)
VITE_API_TIMEOUT=10000

# ==================== 阿里云配置 ====================
# 正式服地址
VITE_PROD_API_URL=https://prod.ahdunyi.com:8000

# 体验服地址
VITE_TEST_API_URL=https://test.ahdunyi.com:8000

# ==================== 客户端配置 ====================
# 客户端类型: web | desktop
VITE_CLIENT_TYPE=web

# 自动刷新间隔 (毫秒)
VITE_AUTO_REFRESH_INTERVAL=5000

# ==================== 日志配置 ====================
# 日志级别: debug | info | warn | error
VITE_LOG_LEVEL=info

# 是否启用控制台日志
VITE_CONSOLE_LOG=true