# ============================================================================
# AHDUNYI Terminal PRO - 生产环境配置模板
# ============================================================================
# 注意：此文件为模板，实际生产配置不应提交到版本控制
# 部署时复制此文件为 .env.production 并填写真实配置
# ============================================================================

# 通用配置
ENVIRONMENT=production
APP_NAME=AHDUNYI Terminal PRO
APP_VERSION=9.1.0
DEBUG=false

# 后端服务配置
# 注意：请使用真实的生产数据库连接信息
DATABASE_URL=mysql+pymysql://username:password@production-db-host:3306/ahdunyi_pro_db?charset=utf8mb4
# 注意：请使用强密码生成JWT密钥，至少32位
JWT_SECRET_KEY=your-production-jwt-secret-key-must-be-strong-and-secure
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# 前端服务配置
VITE_API_BASE_URL_DEVELOPMENT=http://localhost:8000
VITE_API_BASE_URL_PRODUCTION=http://106.15.32.246:8000
VITE_API_BASE_URL_TEST=http://test-server:8000
VITE_API_TIMEOUT=10000
VITE_APP_TITLE=HuiInsight 徽鉴
VITE_APP_VERSION=9.1.0
VITE_APP_COPYRIGHT=© 2026 HuiInsight. The Infrastructure of Risk Control.
VITE_CLIENT_TYPE=desktop
VITE_LOG_LEVEL=info
VITE_CONSOLE_LOG=false
VITE_ENABLE_MOCK=false

# 桌面客户端配置
DESKTOP_SERVER_URL=http://106.15.32.246:8000
DESKTOP_WINDOW_WIDTH=1440
DESKTOP_WINDOW_HEIGHT=900
DESKTOP_LOG_LEVEL=INFO
DESKTOP_LOG_FILE=client.log
DESKTOP_ENABLE_CONSOLE=false

# 功能开关
FEATURE_AUTO_START_MONITOR=true
FEATURE_MEMORY_PROBE_ENABLED=true
FEATURE_MEMORY_MERGE_MODE=override

# 路径配置
PATH_LOGS_DIRECTORY=logs
PATH_DATA_DIRECTORY=data

# 安全配置
PASSWORD_HASH_ALGORITHM=bcrypt
PASSWORD_HASH_ROUNDS=12

# 监控配置
MONITOR_TARGET_PROCESS=small_dimple.exe
MONITOR_HEARTBEAT_INTERVAL=2.0
MONITOR_MAX_SEARCH_DEPTH=8
MONITOR_MEMORY_MAX_REGION_BYTES=524288
MONITOR_MEMORY_MAX_TOTAL_BYTES=12582912