# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.venv/
venv/
.env
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Logs
logs/
*.log

# PyInstaller / 打包产物（勿入库；仅仓库根目录，避免误伤 client/build/*.spec）
/dist/
/dist_release/
/build/
*.exe
*.zip
*.pyz
client/build/_pyinstaller/

# Environment variables (contain sensitive credentials - NEVER commit)
.env
.env.production
.env.local
.env.*.local

# Environment templates (safe to commit)
!.env.example
!.env.production.template
!.env.development

# Frontend environment files (safe to commit)
client/web/.env.development
client/web/.env.production
client/web/.env.test

# Temp / legacy scripts
m1.py
migrate_step*.py
fix_ts_errors*.py
fix_flake8.py
fix_w391.py
fix_build_encoding.py

# Temporary archive folders
_archive_temp_*/

# Temporary diagnostics artifacts
scripts/temp/
docs/ai_conversations/

# OS
.DS_Store
Thumbs.db
*.db
*.sqlite3

# IDE
.idea/
*.swp
*.swo
.vscode/settings.json

# Node / 前端构建（根目录 node_modules；web 子项目单独列出）
/node_modules/
client/web/node_modules/
client/web/dist/
*.tsbuildinfo
.npm/
.eslintcache

# Python virtual env in desktop client
client/desktop/.venv/
